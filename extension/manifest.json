{
  "manifest_version": 3,
  "name": "QA Shield",
  "version": "0.4.0",
  "description": "Automated QA lifecycle — ticket enrichment, verification, security scanning & performance benchmarking",
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": [
    "https://linear.app/creatorfun/*",
    "https://dev.creator.fun/*",
    "https://dev.bep.creator.fun/*",
    "http://localhost:3000/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://linear.app/creatorfun/*"],
      "js": ["content/linear.js"],
      "css": ["content/linear.css"]
    },
    {
      "matches": ["https://dev.creator.fun/*"],
      "js": ["content/staging.js"],
      "css": ["content/staging.css"]
    }
  ],
  "background": {
    "service_worker": "background/worker.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
