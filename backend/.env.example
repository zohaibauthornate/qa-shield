# ── Linear ──────────────────────────────────────────────────────────────────
LINEAR_API_KEY=lin_api_xxx
LINEAR_TEAM_ID=your-team-id-here

# Linear workflow state IDs (get from Linear API or Settings > Workflow)
# LINEAR_STATE_DONE=xxx
# LINEAR_STATE_IN_REVIEW=xxx
# LINEAR_STATE_TODO=xxx

# ── GitHub ──────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_xxx
GITHUB_REPOS=your-org/frontend,your-org/backend
GITHUB_BRANCH=staging
GITHUB_WEBHOOK_SECRET=your-webhook-secret

# ── Your App URLs ────────────────────────────────────────────────────────────
STAGING_URL=https://dev.yourapp.com
STAGING_API_URL=https://api.dev.yourapp.com

# Competitor URLs for performance benchmarking (comma-separated)
COMPETITOR_URLS=https://competitor1.com,https://competitor2.com

# ── AI Providers ─────────────────────────────────────────────────────────────
# Priority: Codex CLI (free) → OpenAI API → Anthropic → Rule-based
#
# Option 1: Codex CLI — free with ChatGPT Plus subscription
#   Setup: npm install -g @openai/codex && codex login
#   No env var needed — uses ~/.codex/auth.json
#
# Option 2: OpenAI API (fallback)
OPENAI_API_KEY=sk-proj-xxx
#
# Option 3: Anthropic (last resort fallback)
ANTHROPIC_API_KEY=sk-ant-xxx

# ── Slack (for alerts + autonomous responder) ────────────────────────────────
SLACK_BOT_TOKEN=xoxb-xxx
REGRESSION_SLACK_CHANNEL=C0XXXXXXXX   # Channel ID for QA reports/alerts

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORT=3000
